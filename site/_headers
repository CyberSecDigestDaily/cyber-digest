/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  # Content Security Policy
  # connect-src covers: CISA KEV, NVD, GitHub Advisory API, EPSS (FIRST.org),
  #   cvefeed.io, CIRCL CVE, OSV.dev, ThreatFox, MalwareBazaar, Feodo Tracker
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://services.nvd.nist.gov https://www.cisa.gov https://api.github.com https://api.first.org https://cvefeed.io https://cve.circl.lu https://api.osv.dev https://threatfox-api.abuse.ch https://mb-api.abuse.ch https://feodotracker.abuse.ch https://urlhaus-api.abuse.ch; img-src 'self' data:; font-src https://fonts.gstatic.com; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'none'
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/digest.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600

/feed.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600

/kev.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=21600

/styles.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/app.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
