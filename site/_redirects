# Cloudflare Pages serves clean URLs automatically (cves.html is served at
# /cves and /cves.html 308-redirects to /cves). Do NOT add "/x /x.html 200"
# rewrites — they fight that built-in redirect and cause ERR_TOO_MANY_REDIRECTS.
# Only keep rules whose target differs from the clean-URL default.
/feed        /feed.xml      200
/cve/:slug   /cve.html      200
/actor/:s    /actor.html    200
